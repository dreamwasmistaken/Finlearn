              <h2 className="text-2xl font-bold mb-6 gradient-text">
                Recommended Lessons
              </h2>
              <div className="space-y-4">
                {recommendedLessons.map((lesson) => (
                  <Link
                    key={lesson.id}
                    href={`/lesson/${lesson.courseId}/${lesson.id}`}
                    className="glass p-6 rounded-xl hover:bg-primary/10 transition group"
                  >
                    <h3 className="font-bold group-hover:text-primary transition mb-2">
                      {lesson.title}
                    </h3>
                    <p className="text-gray-400 text-sm line-clamp-2">
                      {lesson.content.explanation}
                    </p>
                    <p className="text-primary text-sm mt-2">Start Lesson →</p>
                  </Link>
                ))}
              </div>
            </div>
          </div>

          {/* Categories */}
          <div className="mt-16">
            <h2 className="text-2xl font-bold mb-6 gradient-text">
              Browse by Category
            </h2>
            <div className="grid md:grid-cols-4 gap-6">
              {[
                { emoji: '💰', title: 'Money' },
                { emoji: '📈', title: 'Investing' },
                { emoji: '💼', title: 'Business' },
                { emoji: '🧠', title: 'Mindset' },
