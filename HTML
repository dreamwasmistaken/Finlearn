// app/lesson/[courseId]/[lessonId]/page.jsx
'use client';

import { useEffect, useState } from 'react';
import { useAuthStore, useProgressStore } from '@/lib/store';
import { useRouter } from 'next/navigation';
import Navbar from '@/components/Navbar';
import { getLessonById, getCourseById } from '@/lib/data';
import Link from 'next/link';
import { ArrowRight, CheckCircle, AlertCircle } from 'lucide-react';
import { doc, updateDoc, arrayUnion } from 'firebase/firestore';
import { db } from '@/lib/firebase';

export default function LessonPage({ params }) {
  const { user, loading } = useAuthStore();
  const router = useRouter();
  const { addCompletedLesson, completedLessons } = useProgressStore();
  
  const [lesson, setLesson] = useState(null);
  const [course, setCourse] = useState(null);
  const [quizStarted, setQuizStarted] = useState(false);
  const [currentQuestion, setCurrentQuestion] = useState(0);
  const [score, setScore] = useState(0);
  const [answered, setAnswered] = useState([]);
  const [quizCompleted, setQuizCompleted] = useState(false);
  const [lessonCompleted, setLessonCompleted] = useState(false);

  useEffect(() => {
    if (!loading && !user) {
      router.push('/login');
    }
  }, [user, loading, router]);

  useEffect(() => {
    const foundLesson = getLessonById(params.courseId, params.lessonId);
    const foundCourse = getCourseById(params.courseId);
    setLesson(foundLesson);
    setCourse(foundCourse);
    setLessonCompleted(completedLessons.includes(params.lessonId));
  }, [params.courseId, params.lessonId, completedLessons]);

  const handleQuizAnswer = (optionIndex) => {
    const isCorrect = optionIndex === lesson.quiz[currentQuestion].correct;
    setAnswered([...answered, { question: currentQuestion, answer: optionIndex, correct: isCorrect }]);
    
    if (isCorrect) {
      setScore(score + 1);
    }

    if (currentQuestion < lesson.quiz.length - 1) {
      setCurrentQuestion(currentQuestion + 1);
    } else {
      setQuizCompleted(true);
    }
  };

  const handleCompleteLesson = async () => {
    addCompletedLesson(params.lessonId);
    setLessonCompleted(true);

    if (user?.uid) {
      await updateDoc(doc(db, 'users', user.uid), {
        completedLessons: arrayUnion(params.lessonId),
        xp: 100,
        streak: 1,
      });
    }
  };

  if (loading || !lesson || !course) {
    return (
      <main className="min-h-screen bg-dark-bg text-white">
        <Navbar />
        <div className="pt-32 text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-primary mx-auto"></div>
        </div>
      </main>
    );
  }

  if (!user) return null;

  return (
    <main className="min-h-screen bg-dark-bg text-white">
      <Navbar />

      <div className="pt-32 pb-20 px-4 sm:px-6 lg:px-8">
        <div className="max-w-4xl mx-auto">
          {/* Breadcrumb */}
          <div className="flex items-center gap-2 text-gray-400 mb-8">
            <Link href="/courses" className="hover:text-primary transition">
              Courses
            </Link>
            <span>/</span>
            <Link href={`/courses/${course.id}`} className="hover:text-primary transition">
              {course.title}
            </Link>
            <span>/</span>
            <span className="text-primary">{lesson.title}</span>
          </div>

          {/* Lesson Content */}
          {!quizStarted && (
            <div className="glass p-12 rounded-xl space-y-8 mb-8">
              {/* Title */}
              <div>
                <h1 className="text-4xl font-bold gradient-text mb-4">{lesson.title}</h1>
                <div className="flex items-center gap-2 text-green-400">
                  <CheckCircle size={20} />
                  <span>+100 XP when completed</span>
                </div>
              </div>

              {/* Explanation */}
              <div>
                <h2 className="text-xl font-bold mb-3 text-primary">Explanation</h2>
                <p className="text-gray-300 leading-relaxed">
                  {lesson.content.explanation}
                </p>
              </div>

              {/* Key Insight */}
              <div className="bg-primary/10 border border-primary/30 p-6 rounded-lg">
                <h3 className="text-lg font-bold text-primary mb-2">💡 Key Insight</h3>
                <p className="text-gray-300">{lesson.content.keyInsight}</p>
              </div>

              {/* Real World Example */}
              <div>
                <h2 className="text-xl font-bold mb-3 text-accent">Real-World Example</h2>
                <p className="text-gray-300 leading-relaxed">
                  {lesson.content.realWorldExample}
                </p>
              </div>

              {/* Billionaire Thinking */}
              <div className="bg-accent/10 border border-accent/30 p-6 rounded-lg">
                <h3 className="text-lg font-bold text-accent mb-2">🤑 Billionaire Thinking</h3>
                <p className="text-gray-300">{lesson.content.billionaireThinking}</p>
              </div>

              {/* Common Mistakes */}
              <div>
                <h2 className="text-xl font-bold mb-3 text-orange-400">⚠️ Common Mistakes</h2>
                <ul className="space-y-2">
                  {lesson.content.commonMistakes.map((mistake, i) => (
                    <li key={i} className="flex items-start gap-3">
                      <AlertCircle size={20} className="text-orange-400 flex-shrink-0 mt-0.5" />
                      <span className="text-gray-300">{mistake}</span>
                    </li>
                  ))}
                </ul>
              </div>

              {/* Action Steps */}
              <div>
                <h2 className="text-xl font-bold mb-3 text-success">✅ Action Steps</h2>
                <ol className="space-y-2 list-decimal list-inside">
                  {lesson.content.actionSteps.map((step, i) => (
                    <li key={i} className="text-gray-300">{step}</li>
                  ))}
                </ol>
              </div>

              {/* Start Quiz Button */}
              <button
                onClick={() => setQuizStarted(true)}
                className="w-full py-4 bg-gradient-primary text-white font-bold rounded-lg hover:shadow-lg hover:shadow-primary/50 transition flex items-center justify-center gap-2"
              >
                Start Quiz <ArrowRight size={20} />
              </button>
            </div>
          )}

          {/* Quiz */}
          {quizStarted && !quizCompleted && (
            <div className="glass p-12 rounded-xl">
              <div className="mb-8">
                <div className="flex justify-between items-center mb-4">
                  <h2 className="text-2xl font-bold">Quiz: {lesson.title}</h2>
                  <span className="text-primary font-bold">
                    {currentQuestion + 1}/{lesson.quiz.length}
                  </span>
                </div>
                <div className="w-full bg-dark-card rounded-full h-2">
                  <div
                    className="bg-gradient-primary h-2 rounded-full transition-all"
                    style={{
                      width: `${((currentQuestion + 1) / lesson.quiz.length) * 100}%`,
                    }}
                  ></div>
                </div>
              </div>

              <div className="mb-8">
                <h3 className="text-xl font-bold mb-6">
                  {lesson.quiz[currentQuestion].question}
                </h3>
                <div className="space-y-3">
                  {lesson.quiz[currentQuestion].options.map((option, i) => (
                    <button
                      key={i}
                      onClick={() => handleQuizAnswer(i)}
                      className="w-full p-4 bg-dark-card rounded-lg hover:bg-primary/20 transition text-left border border-primary/20 hover:border-primary"
                    >
                      <p className="font-semibold">{option}</p>
                    </button>
                  ))}
                </div>
              </div>
            </div>
          )}

          {/* Quiz Results */}
          {quizCompleted && (
            <div className="glass p-12 rounded-xl text-center space-y-8">
              <div>
                <div className="text-6xl font-bold gradient-text mb-4">
                  {Math.round((score / lesson.quiz.length) * 100)}%
                </div>
                <h2 className="text-3xl font-bold mb-2">Quiz Complete!</h2>
                <p className="text-gray-400">
                  You got {score} out of {lesson.quiz.length} questions correct.
                </p>
              </div>

              {/* Answer Review */}
              <div className="text-left space-y-4">
                <h3 className="text-xl font-bold">Review Your Answers</h3>
                {answered.map((ans, i) => (
                  <div
                    key={i}
                    className={`p-4 rounded-lg ${
                      ans.correct
                        ? 'bg-green-500/10 border border-green-500/30'
                        : 'bg-red-500/10 border border-red-500/30'
                    }`}
                  >
                    <p className="font-bold mb-2">Question {i + 1}</p>
                    <p className="text-sm mb-2">{lesson.quiz[i].question}</p>
                    <p className={`text-sm ${ans.correct ? 'text-green-400' : 'text-red-400'}`}>
                      {ans.correct ? '✓ Correct' : '✗ Incorrect'}
                    </p>
                    {!ans.correct && (
                      <p className="text-sm text-gray-400 mt-2">
                        {lesson.quiz[i].explanation}
                      </p>
                    )}
                  </div>
                ))}
              </div>

              {/* Complete Lesson Button */}
              {!lessonCompleted && (
                <button
                  onClick={handleCompleteLesson}
                  className="w-full py-4 bg-gradient-primary text-white font-bold rounded-lg hover:shadow-lg hover:shadow-primary/50 transition flex items-center justify-center gap-2"
                >
                  <CheckCircle size={20} />
                  Mark Lesson Complete (+100 XP)
                </button>
              )}

              {lessonCompleted && (
                <div className="bg-green-500/20 border border-green-500 p-4 rounded-lg flex items-center justify-center gap-2 text-green-300">
                  <CheckCircle size={20} />
                  <span>Lesson Completed! 🎉</span>
                </div>
              )}

              {/* Next Lesson Button */}
              <Link
                href="/dashboard"
                className="w-full py-4 glass rounded-lg font-bold hover:bg-primary/20 transition flex items-center justify-center gap-2"
              >
                Back to Dashboard <ArrowRight size={20} />
              </Link>
            </div>
          )}
        </div>
      </div>
    </main>
  );
}
};
