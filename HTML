'use client';

import { useEffect, useState } from 'react';
import { useAuthStore, useProgressStore } from '@/lib/store';
import { useRouter } from 'next/navigation';
import Navbar from '@/components/Navbar';
import { Flame, Zap, Trophy, BookOpen, ArrowRight } from 'lucide-react';
import Link from 'next/link';
import { coursesData, getAllLessons } from '@/lib/data';
import { doc, getDoc } from 'firebase/firestore';
import { db } from '@/lib/firebase';

export default function DashboardPage() {
  const { user, loading } = useAuthStore();
  const router = useRouter();
  const [userProfile, setUserProfile] = useState(null);
  const [profileLoading, setProfileLoading] = useState(true);

  useEffect(() => {
    if (!loading && !user) {
      router.push('/login');
    }
  }, [user, loading, router]);

  useEffect(() => {
    if (user?.uid) {
      const fetchProfile = async () => {
        const docRef = doc(db, 'users', user.uid);
        const docSnap = await getDoc(docRef);
        if (docSnap.exists()) {
          setUserProfile(docSnap.data());
        }
        setProfileLoading(false);
      };
      fetchProfile();
    }
  }, [user]);

  if (loading || profileLoading) {
    return (
      <main className="min-h-screen bg-dark-bg text-white">
        <Navbar />
        <div className="pt-32 text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-primary mx-auto"></div>
          <p className="mt-4 text-gray-400">Loading your dashboard...</p>
        </div>
      </main>
    );
  }

  if (!user) return null;

  const lessons = getAllLessons();
  const recommendedLessons = lessons.slice(0, 3);

  return (
    <main className="min-h-screen bg-dark-bg text-white">
      <Navbar />

      <div className="pt-32 pb-20 px-4 sm:px-6 lg:px-8">
        <div className="max-w-6xl mx-auto">
          {/* Welcome Section */}
          <div className="mb-12">
            <h1 className="text-4xl font-bold mb-2 gradient-text">
              Welcome back, {user?.name || 'Learner'}! 👋
            </h1>
            <p className="text-gray-400">Keep building your wealth knowledge.</p>
          </div>

          {/* Stats Grid */}
          <div className="grid md:grid-cols-4 gap-6 mb-12">
            {[
              {
                icon: Zap,
                label: 'XP Points',
                value: userProfile?.xp || 0,
                color: 'text-yellow-400',
              },
              {
                icon: Trophy,
                label: 'Level',
                value: userProfile?.level || 1,
                color: 'text-primary',
              },
              {
                icon: Flame,
                label: 'Streak',
                value: `${userProfile?.streak || 0} days`,
                color: 'text-red-400',
              },
              {
                icon: BookOpen,
                label: 'Lessons Done',
                value: userProfile?.completedLessons?.length || 0,
                color: 'text-accent',
              },
            ].map((stat, i) => (
              <div key={i} className="glass p-6 rounded-xl">
                <stat.icon className={`${stat.color} mb-2`} size={32} />
                <p className="text-gray-400 text-sm">{stat.label}</p>
                <p className="text-3xl font-bold mt-2">{stat.value}</p>
              </div>
            ))}
          </div>

          {/* Continue Learning & Recommended */}
          <div className="grid md:grid-cols-2 gap-12">
            {/* Continue Learning */}
            <div>
              <h2 className="text-2xl font-bold mb-6 gradient-text">
                Continue Learning
              </h2>
              <div className="space-y-4">
                {coursesData.map((course) => (
                  <Link
                    key={course.id}
                    href={`/courses/${course.id}`}
                    className="glass p-6 rounded-xl hover:bg-primary/10 transition flex items-center justify-between"
                  >
                    <div className="flex items-center gap-4">
                      <div className="text-3xl">{course.icon}</div>
                      <div>
                        <h3 className="font-bold">{course.title}</h3>
                        <p className="text-gray-400 text-sm">
                          {course.modules.length} modules
                        </p>
                      </div>
                    </div>
                    <ArrowRight size={20} className="text-primary" />
